rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // スポット情報：誰でも閲覧・登録・編集・削除できる共有データ
    match /spots/{spotId} {
      allow read: if true;
      allow write: if true;
    }
    // お気に入り：本人のアカウントだけが読み書きできる
    match /favorites/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
